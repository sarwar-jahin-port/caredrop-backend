generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid()) @db.Uuid
  email           String           @unique
  passwordHash    String           @map("password_hash")
  role            String
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  customerProfile CustomerProfile?
  sellerProfile   SellerProfile?

  @@map("users")
}

model CustomerProfile {
  userId          String     @id @map("user_id") @db.Uuid
  fullName        String     @map("full_name")
  phone           String
  deliveryAddress String     @map("delivery_address")
  dateOfBirth     DateTime   @map("date_of_birth") @db.Date
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  cartItems       CartItem[]
  orders          Order[]
  reviews         Review[]

  @@map("customer_profiles")
}

model SellerProfile {
  userId          String              @id @map("user_id") @db.Uuid
  pharmacyName    String              @map("pharmacy_name")
  licenseNumber   String              @unique @map("license_number")
  pharmacyAddress String              @map("pharmacy_address")
  phone           String
  isVerified      Boolean             @default(false) @map("is_verified")
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  inventory       PharmacyInventory[]

  @@map("seller_profiles")
}

model Medicine {
  id                   String              @id @default(uuid()) @db.Uuid
  name                 String
  genericName          String              @map("generic_name")
  description          String
  requiresPrescription Boolean             @map("requires_prescription")
  category             String
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  inventory            PharmacyInventory[]
  orderItems           OrderItem[]
  reviews              Review[]

  @@map("medicines")
}

model PharmacyInventory {
  id            String        @id @default(uuid()) @db.Uuid
  sellerId      String        @map("seller_id") @db.Uuid
  medicineId    String        @map("medicine_id") @db.Uuid
  price         Decimal       @db.Decimal(12, 2)
  stockQuantity Int           @map("stock_quantity")
  batchNumber   String        @map("batch_number")
  expiryDate    DateTime      @map("expiry_date") @db.Date
  seller        SellerProfile @relation(fields: [sellerId], references: [userId], onDelete: Cascade)
  medicine      Medicine      @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@unique([sellerId, medicineId, batchNumber], name: "seller_medicine_batch")
  @@map("pharmacy_inventory")
}

model Order {
  id              String          @id @default(uuid()) @db.Uuid
  customerId      String          @map("customer_id") @db.Uuid
  totalAmount     Decimal         @map("total_amount") @db.Decimal(12, 2)
  status          String
  prescriptionUrl String?         @map("prescription_url")
  shippingAddress String          @map("shipping_address")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  customer        CustomerProfile @relation(fields: [customerId], references: [userId], onDelete: Restrict)
  items           OrderItem[]
  tracking        OrderTracking?

  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id              String            @id @default(uuid()) @db.Uuid
  orderId         String            @map("order_id") @db.Uuid
  inventoryId     String            @map("inventory_id") @db.Uuid
  priceAtPurchase Decimal           @map("price_at_purchase") @db.Decimal(12, 2)
  quantity        Int
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventory       PharmacyInventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  medicine        Medicine?         @relation(fields: [medicineId], references: [id])
  medicineId      String?           @db.Uuid

  @@index([orderId])
  @@index([inventoryId])
  @@map("order_items")
}

model CartItem {
  id          String            @id @default(uuid()) @db.Uuid
  customerId  String            @map("customer_id") @db.Uuid
  inventoryId String            @map("inventory_id") @db.Uuid
  quantity    Int
  customer    CustomerProfile   @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  inventory   PharmacyInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@unique([customerId, inventoryId])
  @@index([customerId])
  @@index([inventoryId])
  @@map("cart_items")
}

model Review {
  id         String          @id @default(uuid()) @db.Uuid
  customerId String          @map("customer_id") @db.Uuid
  medicineId String          @map("medicine_id") @db.Uuid
  rating     Int
  comment    String
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  customer   CustomerProfile @relation(fields: [customerId], references: [userId], onDelete: Cascade)
  medicine   Medicine        @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([medicineId])
  @@map("reviews")
}

model OrderTracking {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @unique @map("order_id") @db.Uuid
  status    String
  notes     String
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_tracking")
}
